{
  "expo": {
    "name": "Glowlytics",
    "slug": "Glowlytics",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "glowlytics",
    "backgroundColor": "#FAFAF7",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.glowlytics.app",
      "usesAppleSignIn": true,
      "associatedDomains": [],
      "infoPlist": {
        "NSCameraUsageDescription": "Glowlytics uses the camera to capture guided skin scans and compare trends over time.",
        "NSPhotoLibraryUsageDescription": "Glowlytics needs photo library access to save scan photos.",
        "NSHealthShareUsageDescription": "Glowlytics reads sleep and heart data to add context to your skin trends. It never writes health data.",
        "NSFaceIDUsageDescription": "Glowlytics uses Face ID to securely unlock your account.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.glowlytics.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF7",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Glowlytics uses the camera to capture guided skin scans and compare trends over time."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Glowlytics uses your location to determine regional UV and humidity levels for skin context."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      ["expo-asset", { "assets": ["./assets/models"] }],
      "./plugins/withOnnxModels",
      "expo-font",
      "expo-notifications",
      "expo-web-browser",
      "expo-mail-composer"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "f56f9712-7cc3-48a3-ba5d-710c5e469c3d"
      },
      "router": {}
    },
    "owner": "mufasabrownie"
  }
}
